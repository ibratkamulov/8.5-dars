##############################################################
# FastResult Web — production environment variables
# These NEXT_PUBLIC_* vars are baked into the JS bundle at
# BUILD TIME — they must exist BEFORE running `next build`.
# Copy to apps/web/.env.production on the server.
##############################################################

# ── API base URL ────────────────────────────────────────
# IMPORTANT: do NOT add /api here.
# The code does: BASE = NEXT_PUBLIC_API_URL + "/api"  (see src/lib/api.ts:6)
# Adding /api here would result in double /api in every request URL.
#
# In IP-only mode, nginx routes /api/* to NestJS on port 4000.
# Browser fetches go to: http://13.140.160.169/api/auth/login  etc.
NEXT_PUBLIC_API_URL=http://13.140.160.169

# ── Google Maps (club location map uses Leaflet — key optional) ──
# Only needed if you switched from Leaflet to Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=CHANGE_ME
