{
  "name": "fastresult",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade fitness management SaaS platform.",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @fastresult/api prisma:generate",
    "db:migrate": "pnpm --filter @fastresult/api prisma:migrate"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
